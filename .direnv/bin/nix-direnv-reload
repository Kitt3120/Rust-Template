#!/usr/bin/env bash
set -e
if [[ ! -d "/home/torben/Nextcloud/Programmierung/Rust/rust_template" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/home/torben/Nextcloud/Programmierung/Rust/rust_template")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/home/torben/Nextcloud/Programmierung/Rust/rust_template" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/home/torben/Nextcloud/Programmierung/Rust/rust_template/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/home/torben/Nextcloud/Programmierung/Rust/rust_template/.envrc" "/home/torben/Nextcloud/Programmierung/Rust/rust_template/.direnv"/*.rc
